% Inline blanks using \fillin (no \answerline question-number prefix).
% Space between printed answer and rule: exam default \answerclearance is tight; widen with:
\newlength{\fillinrulegap}
\setlength{\fillinrulegap}{0.55ex}
\makeatletter
\newcommand{\exam@fillinspaced}[2]{%
  \begingroup
  \setlength{\answerclearance}{\fillinrulegap}%
  \fillin[#1][#2]%
  \endgroup
}%
\newcommand{\labeledfillin}[2]{%
  \par\nobreak\vskip\answerskip
  \noindent#1:\ \exam@fillinspaced{#2}{2.3in}%
}%
% Optional arg = blank width (default 2.2in); mandatory arg = answer key for \printanswers.
\newcommand{\rightfillin}[2][2.2in]{%
  \par\nobreak\vskip\answerskip
  \noindent\hfill\exam@fillinspaced{#2}{#1}%
}%
% Visual-only underlined blank in running text (e.g. MCQ stems). Does not print an answer.
% For blanks that should show the key when \printanswers is on, use \fillin[Answer][width]
% or \exam@fillinspaced{Answer}{width} (see above). The exam class has no global option
% to turn every question into fill-in; use \fillin / \makeemptybox / \answerline per item.
\newcommand{\blank}[1][6em]{\underline{\hspace{#1}}}%
\makeatother

